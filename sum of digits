#include <stdio.h>

int main() {
    int number, digit, sum = 0;

    // Input
    printf("Enter a number: ");
    scanf("%d", &number);

    // Calculate sum of digits
    while (number != 0) {
        digit = number % 10;   // Get last digit
        sum += digit;          // Add to sum
        number = number / 10;  // Remove last digit
    }

    // Output
    printf("Sum of digits = %d\n", sum);

    return 0;
}
